{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.internal/contracts/events/envelope.schema.json",
  "title": "Canonical Event Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "event_version",
    "event_time",
    "ingested_at",
    "source_system",
    "message_id",
    "correlation_id",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "description": "Globally unique event identifier."
    },
    "event_type": {
      "type": "string",
      "description": "Canonical event name."
    },
    "event_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "event_time": {
      "type": "string",
      "format": "date-time"
    },
    "ingested_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_system": {
      "type": "string"
    },
    "tenant_id": {
      "type": ["string", "null"]
    },
    "message_id": {
      "type": "string"
    },
    "correlation_id": {
      "type": "string"
    },
    "trace_id": {
      "type": ["string", "null"]
    },
    "actor_type": {
      "type": ["string", "null"],
      "enum": ["user", "system", "scheduler", "provider", "service", null]
    },
    "payload": {
      "type": "object"
    }
  }
}