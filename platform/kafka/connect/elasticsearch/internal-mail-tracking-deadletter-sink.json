{
  "connector.class": "io.confluent.connect.elasticsearch.ElasticsearchSinkConnector",
  "tasks.max": "1",
  "topics": "evt.mail.internal.tracking.dashboard.dlq",
  "external.resource.usage": "index",
  "topic.to.external.resource.mapping": "evt.mail.internal.tracking.dashboard.dlq:internal-mail-tracking-deadletter",
  "connection.url": "http://elasticsearch:9200",
  "type.name": "_doc",
  "key.ignore": "true",
  "schema.ignore": "true",
  "write.method": "insert",
  "behavior.on.null.values": "ignore",
  "max.in.flight.requests": "1",
  "batch.size": "200",
  "max.buffered.records": "5000",
  "linger.ms": "500",
  "read.timeout.ms": "30000",
  "flush.timeout.ms": "180000",
  "errors.tolerance": "all",
  "errors.log.enable": "true",
  "errors.log.include.messages": "true",
  "value.converter": "org.apache.kafka.connect.storage.StringConverter",
  "transforms": "WrapValue,AddKafkaMetadata",
  "transforms.WrapValue.type": "org.apache.kafka.connect.transforms.HoistField$Value",
  "transforms.WrapValue.field": "raw_payload",
  "transforms.AddKafkaMetadata.type": "org.apache.kafka.connect.transforms.InsertField$Value",
  "transforms.AddKafkaMetadata.topic.field": "kafka_topic",
  "transforms.AddKafkaMetadata.partition.field": "kafka_partition",
  "transforms.AddKafkaMetadata.offset.field": "kafka_offset",
  "transforms.AddKafkaMetadata.timestamp.field": "kafka_timestamp"
}
