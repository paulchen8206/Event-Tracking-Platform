# ── Orchestration API – Spark command overrides ──────────────────────────────
# Local dev defaults to echo stubs. Override with real spark-submit or java -jar
# commands for staging/prod or when running the dev-lakehouse profile locally.
# SPARK_APP_CANONICAL_COMMAND=java -jar /path/to/canonical-lakehouse-consumer.jar
# SPARK_APP_OPS_COMMAND=echo 'No-op placeholder for internal Spark projection app'

# ── dbt / Snowflake credentials ───────────────────────────────────────────────
DBT_SNOWFLAKE_ACCOUNT=<your-snowflake-account>
DBT_SNOWFLAKE_USER=<your-snowflake-user>
DBT_SNOWFLAKE_PASSWORD=<your-snowflake-password>
DBT_SNOWFLAKE_ROLE=TRANSFORMER
DBT_SNOWFLAKE_WAREHOUSE=ANALYTICS_DEV_WH
DBT_SNOWFLAKE_DATABASE=EVENT_TRACKING
DBT_SNOWFLAKE_TARGET_SCHEMA=ANALYTICS_SEMANTIC_DEV
DBT_SNOWFLAKE_ICEBERG_SCHEMA=ICEBERG_CUSTOMER_ANALYTICS
